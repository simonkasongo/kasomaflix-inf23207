<Page x:Class="KasomaFlix.Presentation.Views.AccueilCatalogue"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="AccueilCatalogue">

    <Grid Background="#141414">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#000000" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="KASOMAFLIX"
                           Foreground="#E50914" FontSize="24"
                           FontWeight="Bold" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="20,0">
                    <TextBox x:Name="TxtRecherche" Width="300" Padding="5" FontSize="14"
                             Text="Rechercher films, séries..."
                             Foreground="#AAAAAA" Background="#333333"
                             BorderBrush="#E50914" BorderThickness="1"
                             GotFocus="TxtRecherche_GotFocus" LostFocus="TxtRecherche_LostFocus"/>
                    <Button x:Name="BtnRechercher" Content="Rechercher" Background="#E50914"
                            Foreground="White" Padding="5,5"
                            Margin="5,0,0,0" BorderThickness="0" Click="BtnRechercher_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="S'inscrire" Background="#444444"
                            Foreground="White" Padding="8,5" Margin="5,0"
                            BorderThickness="0" Click="Inscription_Click"/>
                    <Button Content="Ouvrir session" Background="#E50914"
                            Foreground="White" Padding="8,5" Margin="5,0"
                            BorderThickness="0" Click="Connexion_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CATALOGUE -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <TextBlock Text="Catalogue de Films" Foreground="White"
                           FontSize="28" FontWeight="SemiBold"
                           Margin="0,0,0,20"/>

                <WrapPanel x:Name="MovieGrid" ItemWidth="200" ItemHeight="350"
                           Margin="0,10" HorizontalAlignment="Center">
                    <!-- Les films seront chargés dynamiquement depuis la base de données -->
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

