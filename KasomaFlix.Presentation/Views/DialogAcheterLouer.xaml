<Window x:Class="KasomaFlix.Presentation.Views.DialogAcheterLouer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acheter ou Louer un Film" 
        Height="550" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#141414">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0" x:Name="TxtTitreFilm" 
                   Text="Titre du Film" 
                   Foreground="White" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   TextWrapping="Wrap"
                   Margin="0,0,0,20"/>

        <!-- Informations de prix -->
        <StackPanel Grid.Row="1" Margin="0,0,0,30">
            <TextBlock Text="Choisissez une option :" 
                       Foreground="White" 
                       FontSize="16" 
                       FontWeight="SemiBold" 
                       Margin="0,0,0,15"/>
            
            <!-- Option Achat -->
            <Border Background="#2A2A2A" 
                    BorderBrush="#444444" 
                    BorderThickness="1" 
                    CornerRadius="5" 
                    Padding="15" 
                    Margin="0,0,0,15"
                    x:Name="BorderAchat"
                    MouseLeftButtonDown="BorderAchat_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton Grid.Column="0" 
                                 x:Name="RadioAchat" 
                                 IsChecked="True"
                                 VerticalAlignment="Center" 
                                 Margin="0,0,15,0"
                                 Checked="RadioAchat_Checked"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Acheter le film" 
                               Foreground="White" 
                               FontSize="16" 
                               FontWeight="Bold"/>
                        <TextBlock x:Name="TxtPrixAchat" 
                                   Text="Prix: 0.00 $" 
                                   Foreground="#AAAAAA" 
                                   FontSize="14" 
                                   Margin="0,5,0,0"/>
                        <TextBlock Text="Accès permanent au film" 
                                   Foreground="#888888" 
                                   FontSize="12" 
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" 
                               Text="✓" 
                               Foreground="#00FF00" 
                               FontSize="24" 
                               FontWeight="Bold"
                               x:Name="CheckAchat"
                               Visibility="Visible"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Option Location -->
            <Border Background="#2A2A2A" 
                    BorderBrush="#444444" 
                    BorderThickness="1" 
                    CornerRadius="5" 
                    Padding="15"
                    x:Name="BorderLocation"
                    MouseLeftButtonDown="BorderLocation_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton Grid.Column="0" 
                                 x:Name="RadioLocation" 
                                 IsChecked="False"
                                 VerticalAlignment="Center" 
                                 Margin="0,0,15,0"
                                 Checked="RadioLocation_Checked"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Louer le film" 
                                   Foreground="White" 
                                   FontSize="16" 
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="TxtPrixLocation" 
                                   Text="Prix: 0.00 $" 
                                   Foreground="#AAAAAA" 
                                   FontSize="14" 
                                   Margin="0,5,0,0"/>
                        <TextBlock Text="Accès temporaire (48h)" 
                                   Foreground="#888888" 
                                   FontSize="12" 
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" 
                               Text="✓" 
                               Foreground="#00FF00" 
                               FontSize="24" 
                               FontWeight="Bold"
                               x:Name="CheckLocation"
                               Visibility="Collapsed"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Solde actuel -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,15">
            <TextBlock Text="Votre solde actuel : " 
                       Foreground="#AAAAAA" 
                       FontSize="14"/>
            <TextBlock x:Name="TxtSoldeActuel" 
                       Text="Chargement..." 
                       Foreground="#00FF00" 
                       FontSize="14" 
                       FontWeight="Bold"/>
        </StackPanel>

        <!-- Message d'erreur si solde insuffisant -->
        <TextBlock Grid.Row="3" 
                   x:Name="TxtMessageErreur" 
                   Text="" 
                   Foreground="#FF6B6B" 
                   FontSize="12" 
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   Margin="0,0,0,15"/>

        <!-- Boutons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annuler" 
                    Background="#444444" 
                    Foreground="White" 
                    Padding="15,8" 
                    BorderThickness="0" 
                    Click="Annuler_Click"
                    Margin="0,0,10,0"/>
            <Button Content="Confirmer" 
                    x:Name="BtnConfirmer"
                    Background="#E50914" 
                    Foreground="White" 
                    Padding="15,8" 
                    FontWeight="Bold"
                    BorderThickness="0" 
                    Click="Confirmer_Click"/>
        </StackPanel>
    </Grid>
</Window>
