<Page x:Class="KasomaFlix.Presentation.Views.LecteurVideo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1200"
      Title="LecteurVideo">

    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Zone de Lecture Vidéo (MediaElement) -->
        <MediaElement Grid.Row="0" x:Name="VideoPlayer" Stretch="Uniform" LoadedBehavior="Manual" UnloadedBehavior="Stop"/>

        <!-- Contrôles du Lecteur -->
        <Border Grid.Row="1" Background="#1A1A1A" Padding="10">
            <StackPanel>
                <!-- Barre de Progression -->
                <Slider x:Name="TimelineSlider" Minimum="0" Maximum="100" Value="25" Foreground="#E50914" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Contrôles de Lecture (Play/Pause/Stop) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Content="❚❚" FontSize="18" Background="Transparent" Foreground="White" BorderThickness="0" Margin="0,0,10,0" Click="Pause_Click"/>
                        <Button Content="▶" FontSize="18" Background="Transparent" Foreground="White" BorderThickness="0" Margin="0,0,10,0" Click="Play_Click"/>
                        <Button Content="■" FontSize="18" Background="Transparent" Foreground="White" BorderThickness="0" Click="Stop_Click"/>

                        <!-- Temps écoulé / Durée totale -->
                        <TextBlock Text="00:25 / 01:45" Foreground="White" VerticalAlignment="Center" Margin="20,0,0,0"/>
                    </StackPanel>

                    <!-- Bouton pour Coter le Film (Retour à E04) -->
                    <Button Grid.Column="1" Content="Coter le Film (Retour E04)" Background="#E50914" Foreground="White" Padding="10,5" BorderThickness="0" Click="CoterFilm_Click" Grid.ColumnSpan="2" Height="26" Margin="864,0,0,0" VerticalAlignment="Top"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Bouton de Fermeture (Retour à E04) -->
        <Button Content="X" Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" Background="#E50914" Foreground="White" FontSize="18" Width="30" Height="30" Click="FermerLecteur_Click"/>
    </Grid>
</Page>

