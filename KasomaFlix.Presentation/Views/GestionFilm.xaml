<Page x:Class="KasomaFlix.Presentation.Views.GestionFilm"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="GestionFilm">

    <Page.Resources>
        <!-- Style pour les items du ComboBox -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A3A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E50914"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Style personnalisé pour le ComboBox -->
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                        Grid.Column="2" 
                                        Focusable="false"
                                        ClickMode="Press"
                                        IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Path x:Name="Arrow" 
                                                      Grid.Column="1" 
                                                      HorizontalAlignment="Right" 
                                                      VerticalAlignment="Center" 
                                                      Margin="0,0,8,0" 
                                                      Fill="White" 
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" 
                                            IsHitTestVisible="False" 
                                            Content="{TemplateBinding SelectionBoxItem}"
                                            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                            ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                            Margin="8,0,23,0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"/>
                            <TextBox x:Name="PART_EditableTextBox"
                                   Style="{x:Null}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Margin="8,0,23,0"
                                   Focusable="True"
                                   Background="Transparent"
                                   Foreground="White"
                                   BorderThickness="0"
                                   Visibility="Hidden"
                                   IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup Name="Popup"
                                 Placement="Bottom"
                                 IsOpen="{TemplateBinding IsDropDownOpen}"
                                 AllowsTransparency="True"
                                 Focusable="False"
                                 PopupAnimation="Slide">
                                <Grid Name="DropDown"
                                    SnapsToDevicePixels="True"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                          Background="#2A2A2A"
                                          BorderThickness="1"
                                          BorderBrush="#444444">
                                        <ScrollViewer Margin="0" 
                                                    CanContentScroll="True" 
                                                    VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="#141414">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER ADMIN -->
        <Border Grid.Row="0" Background="#E50914" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="ADMINISTRATION KASOMAFLIX" Foreground="White" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Tableau de Bord" Background="#444444" Foreground="White" Padding="8,5" Margin="5,0" BorderThickness="0" Click="TableauBord_Click"/>
                    <Button Content="Déconnexion" Background="#444444" Foreground="White" Padding="8,5" Margin="5,0" BorderThickness="0" Click="Deconnexion_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENU PRINCIPAL -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40">
                <TextBlock Text="Gestion des Informations du Film" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,0,0,30"/>

                <!-- Section de sélection de film -->
                <Border Background="#222222" Padding="20" CornerRadius="5" Margin="0,0,0,30" Width="700" HorizontalAlignment="Left">
                    <StackPanel>
                        <TextBlock Text="Sélectionner un film à modifier" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Film :" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox Grid.Column="1" x:Name="CmbFilmsExistants" Style="{StaticResource ModernComboBoxStyle}" SelectionChanged="CmbFilmsExistants_SelectionChanged">
                                <ComboBoxItem Content="-- Nouveau film --" Tag="-1"/>
                            </ComboBox>
                            <Button Grid.Column="2" Content="Actualiser" Background="#555555" Foreground="White" Padding="10,5" Margin="10,0,0,0" Click="ActualiserListe_Click"/>
                        </Grid>
                        <TextBlock Text="Sélectionnez '-- Nouveau film --' pour ajouter un nouveau film, ou choisissez un film existant pour le modifier." 
                                   Foreground="#AAAAAA" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Grid Width="700" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Champs basés sur la classe Film -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Titre :" Foreground="White" VerticalAlignment="Center" Margin="0,10"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtTitre" Padding="8" Background="#333333" Foreground="White" BorderBrush="#444444" BorderThickness="1" Margin="0,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Année :" Foreground="White" VerticalAlignment="Center" Margin="0,10"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtAnnee" Padding="8" Background="#333333" Foreground="White" BorderBrush="#444444" BorderThickness="1" Margin="0,5"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Durée (min) :" Foreground="White" VerticalAlignment="Center" Margin="0,10"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtDuree" Padding="8" Background="#333333" Foreground="White" BorderBrush="#444444" BorderThickness="1" Margin="0,5"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Catégorie :" Foreground="White" VerticalAlignment="Center" Margin="0,10"/>
                    <ComboBox Grid.Row="3" Grid.Column="1" x:Name="CmbCategorie" Style="{StaticResource ModernComboBoxStyle}" Margin="0,5">
                        <ComboBoxItem Content="Action"/>
                        <ComboBoxItem Content="Comédie"/>
                        <ComboBoxItem Content="Drame"/>
                        <ComboBoxItem Content="Horreur"/>
                        <ComboBoxItem Content="Thriller"/>
                        <ComboBoxItem Content="Science-Fiction"/>
                        <ComboBoxItem Content="Romance"/>
                        <ComboBoxItem Content="Animation"/>
                        <ComboBoxItem Content="Documentaire"/>
                        <ComboBoxItem Content="Aventure"/>
                    </ComboBox>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Réalisateur :" Foreground="White" VerticalAlignment="Center" Margin="0,10"/>
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtRealisateur" Padding="8" Background="#333333" Foreground="White" BorderBrush="#444444" BorderThickness="1" Margin="0,5"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Acteurs :" Foreground="White" VerticalAlignment="Center" Margin="0,10"/>
                    <TextBox Grid.Row="5" Grid.Column="1" x:Name="TxtActeurs" Padding="8" Background="#333333" Foreground="White" BorderBrush="#444444" BorderThickness="1" Margin="0,5"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Description :" Foreground="White" VerticalAlignment="Center" Margin="0,10"/>
                    <TextBox Grid.Row="6" Grid.Column="1" x:Name="TxtDescription" Padding="8" Background="#333333" Foreground="White" BorderBrush="#444444" BorderThickness="1" TextWrapping="Wrap" AcceptsReturn="True" Height="100" Margin="0,5"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Chemin Affiche :" Foreground="White" VerticalAlignment="Center" Margin="0,10"/>
                    <TextBox Grid.Row="7" Grid.Column="1" x:Name="TxtCheminAffiche" Padding="8" Background="#333333" Foreground="White" BorderBrush="#444444" BorderThickness="1" Margin="0,5"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Prix Achat :" Foreground="White" VerticalAlignment="Center" Margin="0,10"/>
                    <TextBox Grid.Row="8" Grid.Column="1" x:Name="TxtPrixAchat" Padding="8" Background="#333333" Foreground="White" BorderBrush="#444444" BorderThickness="1" Margin="0,5"/>

                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Prix Location :" Foreground="White" VerticalAlignment="Center" Margin="0,10"/>
                    <TextBox Grid.Row="9" Grid.Column="1" x:Name="TxtPrixLocation" Padding="8" Background="#333333" Foreground="White" BorderBrush="#444444" BorderThickness="1" Margin="0,5"/>

                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Fichier vidéo :" Foreground="White" VerticalAlignment="Center" Margin="0,10"/>
                    <TextBox Grid.Row="10" Grid.Column="1" x:Name="TxtFichierVideo" Padding="8" Background="#333333" Foreground="White" BorderBrush="#444444" BorderThickness="1" Margin="0,5"
                             ToolTip="Nom du fichier présent dans le dossier FilmsLocaux (ex: demo.mp4)"/>
                </Grid>

                <!-- Boutons d'Action -->
                <StackPanel Orientation="Horizontal" Margin="0,40,0,0" HorizontalAlignment="Left">
                    <Button x:Name="BtnSauvegarder" Content="Sauvegarder" Background="#E50914" Foreground="White" Padding="15,10" FontSize="16" FontWeight="Bold" Click="Sauvegarder_Click" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E50914"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5222D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Nouveau Film" Background="#444444" Foreground="White" Padding="15,10" FontSize="16" Margin="15,0,0,0" Click="AjouterNouveau_Click" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#444444"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#555555"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="BtnSupprimer" Content="Supprimer" Background="#DC3545" Foreground="White" Padding="15,10" FontSize="16" Margin="15,0,0,0" Click="Supprimer_Click" Cursor="Hand" IsEnabled="False">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#DC3545"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C82333"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#666666"/>
                                        <Setter Property="Foreground" Value="#AAAAAA"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
    </Page>

