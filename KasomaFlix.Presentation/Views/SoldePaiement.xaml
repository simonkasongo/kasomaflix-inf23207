<Page x:Class="KasomaFlix.Presentation.Views.SoldePaiement"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="SoldePaiement">

    <Grid Background="#141414">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#000000" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="KASOMAFLIX" Foreground="#E50914" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Accueil" Background="#444444" Foreground="White" Padding="8,5" Margin="5,0" BorderThickness="0" Click="Accueil_Click"/>
                    <Button Content="Mon Compte" Background="#E50914" Foreground="White" Padding="8,5" Margin="5,0" BorderThickness="0" Click="MonCompte_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENU PRINCIPAL -->
        <StackPanel Grid.Row="1" Margin="40">
            <TextBlock Text="Solde et Gestion des Paiements" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,0,0,30"/>

            <!-- Section Solde Actuel -->
            <Border Background="#222222" Padding="20" CornerRadius="5" Margin="0,0,0,40">
                <StackPanel>
                    <TextBlock Text="Solde Actuel du Compte" Foreground="#AAAAAA" FontSize="18" Margin="0,0,0,10"/>
                    <TextBlock x:Name="TxtSolde" Text="25.50 $" Foreground="#00FF00" FontSize="48" FontWeight="Bold"/>
                    <TextBlock Text="Ce solde peut être utilisé pour les achats de films ou les abonnements." Foreground="#AAAAAA" FontSize="14" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Section Approvisionnement (Basé sur Approvisionner compte) -->
            <TextBlock Text="Approvisionner le Compte" Foreground="White" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,15"/>
            <Grid Width="500" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Montant à ajouter :" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" x:Name="TxtMontant" Padding="8" Background="#333333" Foreground="White" BorderBrush="#444444" BorderThickness="1" Text="20.00"/>
                <Button Grid.Column="2" Content="Ajouter au Solde" Background="#E50914" Foreground="White" Padding="8,5" Margin="10,0,0,0" Click="AjouterSolde_Click"/>
            </Grid>

            <!-- Section Modes de Paiement (Basé sur la classe CarteCredit) -->
            <TextBlock Text="Modes de Paiement Enregistrés" Foreground="White" FontSize="24" FontWeight="SemiBold" Margin="0,40,0,15"/>
            <StackPanel Width="500" HorizontalAlignment="Left">
                <StackPanel x:Name="PanelCartesCredit" Margin="0,0,0,15">
                    <!-- Les cartes seront ajoutées dynamiquement ici -->
                </StackPanel>
                <TextBlock x:Name="TxtAucuneCarte" 
                           Text="Aucun mode de paiement enregistré." 
                           Foreground="#AAAAAA" 
                           FontSize="14"
                           Margin="0,5"
                           Visibility="Collapsed"/>
                <Button Content="Ajouter un nouveau mode de paiement" 
                        Background="#444444" 
                        Foreground="White" 
                        Padding="8,5" 
                        Margin="0,15,0,0" 
                        HorizontalAlignment="Left" 
                        Click="AjouterPaiement_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>

